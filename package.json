{
  "name": "html-presentation-editor",
  "version": "2.0.19",
  "description": "Local HTML presentation editor with Playwright regression coverage.",
  "private": true,
  "scripts": {
    "start": "node scripts/run-local-editor.js",
    "serve": "node scripts/static-server.js . 4173 127.0.0.1",
    "serve:host": "node scripts/static-server.js . 4173 0.0.0.0",
    "docker:build": "docker build -t html-presentation-editor:local .",
    "docker:run": "docker run --rm -p 4173:4173 html-presentation-editor:local",
    "smoke": "npm run test:gate-a",
    "test:pilot": "npm run test:gate-a && npm run test:asset-parity",
    "test:install-browsers": "playwright install",
    "test": "playwright test",
    "test:pw": "playwright test",
    "test:pw:headed": "playwright test --headed",
    "test:pw:update": "playwright test --update-snapshots",
    "test:asset-parity": "node scripts/validate-export-asset-parity.js",
    "test:gate-a": "playwright test tests/playwright/specs/shell.smoke.spec.js tests/playwright/specs/click-through.spec.js tests/playwright/specs/selection-engine-v2.spec.js tests/playwright/specs/honest-feedback.spec.js tests/playwright/specs/broken-asset-banner.spec.js tests/playwright/specs/layers-tree-nav.spec.js tests/playwright/specs/layers-rename-context.spec.js tests/playwright/specs/import-pipeline-v2.spec.js tests/playwright/specs/multi-select.spec.js tests/playwright/specs/alignment-toolbar.spec.js tests/playwright/specs/opacity-rotate.spec.js tests/playwright/specs/keyboard-shortcuts-ppt.spec.js tests/playwright/specs/pptx-fidelity-v2.spec.js tests/playwright/specs/error-recovery-boundary.spec.js tests/playwright/specs/onboarding-v2.spec.js tests/playwright/specs/inspector-validators-badges.spec.js tests/playwright/specs/deck-health-boundary.spec.js tests/playwright/specs/undo-toast-onboarding.spec.js tests/playwright/specs/import-corpus.spec.js tests/playwright/specs/bridge-mutation-schema.spec.js tests/playwright/specs/golden-export-clean.spec.js tests/playwright/specs/recovery-scenarios.spec.js tests/playwright/specs/long-session-sync.spec.js tests/playwright/specs/docs-sync.spec.js tests/playwright/specs/workspace-settings.spec.js tests/playwright/specs/click-blocked-feedback.spec.js tests/playwright/specs/shortcut-discovery-hints.spec.js tests/playwright/specs/inspector-basic-geometry.spec.js tests/playwright/specs/inspector-empty-hint.spec.js tests/playwright/specs/bridge-mutation-security.spec.js tests/playwright/specs/bridge-inbound-validation.spec.js tests/playwright/specs/bridge-proto-pollution.spec.js tests/playwright/specs/perf-budget.spec.js tests/playwright/specs/bridge-file-origin.spec.js tests/playwright/specs/pptx-export-roundtrip.spec.js --project=chromium-desktop",
    "test:gate-b": "playwright test tests/playwright/specs/shell.smoke.spec.js tests/playwright/specs/click-through.spec.js tests/playwright/specs/selection-engine-v2.spec.js tests/playwright/specs/layer-navigation.spec.js tests/playwright/specs/overlap-recovery.spec.js tests/playwright/specs/stage-o-layers-lock-group.spec.js tests/playwright/specs/editor.regression.spec.js tests/playwright/specs/asset-parity.spec.js tests/playwright/specs/honest-feedback.spec.js tests/playwright/specs/entity-kinds-registry.spec.js tests/playwright/specs/telemetry-viewer.spec.js tests/playwright/selection-perf.spec.js tests/playwright/specs/shortcuts-table.spec.js --project=chromium-desktop && playwright test tests/playwright/specs/shell.smoke.spec.js tests/playwright/specs/editor.regression.spec.js tests/playwright/specs/asset-parity.spec.js --project=chromium-shell-1100",
    "test:gate-c": "playwright test tests/playwright/specs/shell.smoke.spec.js tests/playwright/specs/editor.regression.spec.js tests/playwright/specs/click-through.spec.js tests/playwright/specs/selection-engine-v2.spec.js --project=firefox-desktop --project=webkit-desktop",
    "test:gate-d": "playwright test tests/playwright/specs/shell.smoke.spec.js tests/playwright/specs/editor.regression.spec.js tests/playwright/specs/tablet-honest.spec.js --project=chromium-mobile-390 --project=chromium-mobile-640 --project=chromium-tablet-820",
    "test:gate-e": "npm run test:asset-parity && playwright test tests/playwright/specs/asset-parity.spec.js --project=chromium-desktop",
    "test:gate-f": "playwright test",
    "test:gate-contract": "playwright test --project=gate-contract",
    "test:gate-a11y": "node -e \"process.env.PLAYWRIGHT_TEST_SERVER_PORT='41735'; require('child_process').spawnSync('npx',['playwright','test','tests/a11y/','--project=chromium-desktop','--config','playwright.a11y.config.js'],{stdio:'inherit',shell:true});\"",
    "typecheck": "tsc --noEmit",
    "test:gate-types": "tsc --noEmit",
    "test:unit": "node --test tests/unit/store.spec.js tests/unit/selection-slice.spec.js tests/unit/history-patches.spec.js tests/unit/schedule-selection-render.spec.js tests/unit/surface-manager.spec.js tests/unit/banners.spec.js",
    "test:gate-visual": "node -e \"process.env.PLAYWRIGHT_TEST_SERVER_PORT='41736'; require('child_process').spawnSync('npx',['playwright','test','tests/visual/','--project=chromium-visual'],{stdio:'inherit',shell:true});\"",
    "test:gate-visual:update": "node -e \"process.env.PLAYWRIGHT_TEST_SERVER_PORT='41736'; require('child_process').spawnSync('npx',['playwright','test','tests/visual/','--project=chromium-visual','--update-snapshots'],{stdio:'inherit',shell:true});\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kuznetzdev/html_presentation_editor.git"
  },
  "keywords": [
    "playwright",
    "html",
    "presentation",
    "qa"
  ],
  "author": "Codex hardening workflow",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "bugs": {
    "url": "https://github.com/kuznetzdev/html_presentation_editor/issues"
  },
  "homepage": "https://github.com/kuznetzdev/html_presentation_editor#readme",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.58.2",
    "adm-zip": "^0.5.17",
    "typescript": "^5.9.3"
  }
}
